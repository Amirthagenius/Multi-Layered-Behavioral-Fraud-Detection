      "source": [
        "# ==========================================================\n",
        "# 📦 DATASET GENERATION NOTEBOOK (ORGANIZER ONLY)\n",
        "# ==========================================================\n",
        "# ⚠️ IMPORTANT:\n",
        "# Students DO NOT need to run this notebook.\n",
        "# Dataset is already generated and available in /data folder.\n",
        "# This notebook is for reference only.\n",
        "\n",
        "# ==========================================================\n",
        "# 🎯 PURPOSE OF THIS DATASET\n",
        "# ==========================================================\n",
        "# This dataset simulates customer behavior and transactions.\n",
        "# It supports multiple machine learning problems such as:\n",
        "# - Customer churn prediction\n",
        "# - Fraud detection\n",
        "# - Revenue prediction"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 2,
      "id": "9936a044",
      "metadata": {
        "id": "9936a044"
      },
      "outputs": [],
      "source": [
        "# ==========================================================\n",
        "# 📚 LIBRARIES\n",
        "# ==========================================================\n",
        "import pandas as pd\n",
        "import numpy as np"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 3,
      "id": "2f193aca",
      "metadata": {
        "id": "2f193aca"
      },
      "outputs": [],
      "source": [
        "# Fix randomness for reproducibility\n",
        "np.random.seed(42)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 4,
      "id": "d7680ae7",
      "metadata": {
        "id": "d7680ae7"
      },
      "outputs": [],
      "source": [
        "# ==========================================================\n",
        "# 🔢 STEP 1 — CREATE BASE DATA\n",
        "# ==========================================================\n",
        "# Number of records\n",
        "n = 5000\n",
        "\n",
        "df = pd.DataFrame({\n",
        "    \"customer_id\": range(1, n+1),  # Unique ID\n",
        "    \"age\": np.random.randint(18, 70, n),  # Customer age\n",
        "    \"gender\": np.random.choice([\"Male\", \"Female\"], n),\n",
        "    \"country\": np.random.choice([\"UK\", \"US\", \"India\", \"Germany\"], n),\n",
        "    \"tenure_months\": np.random.randint(1, 60, n),  # Customer duration\n",
        "    \"monthly_spend\": np.random.uniform(20, 500, n),  # Monthly spending\n",
        "    \"num_transactions\": np.random.randint(1, 100, n),  # Activity level\n",
        "    \"last_login_days\": np.random.randint(1, 30, n),  # Engagement\n",
        "    \"support_tickets\": np.random.randint(0, 10, n),\n",
        "    \"payment_method\": np.random.choice([\"Card\", \"PayPal\", \"Crypto\"], n),\n",
        "    \"is_active\": np.random.choice([0, 1], n)\n",
        "})"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 5,
      "id": "91d7b554",
      "metadata": {
        "id": "91d7b554"
      },
      "outputs": [],
      "source": [
        "# ==========================================================\n",
        "# 🔧 STEP 2 — FEATURE ENGINEERING (PRE-BUILT)\n",
        "# ==========================================================\n",
        "# These are example features students can use or improve\n",
        "\n",
        "df[\"total_spend\"] = df[\"monthly_spend\"] * df[\"tenure_months\"]\n",
        "df[\"avg_transaction_value\"] = df[\"total_spend\"] / (df[\"num_transactions\"] + 1)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 6,
      "id": "fe0921cb",
      "metadata": {
        "id": "fe0921cb"
      },
      "outputs": [],
      "source": [
        "# ==========================================================\n",
        "# 🎯 STEP 3 — TARGET VARIABLES (MULTI-PROBLEM SUPPORT)\n",
        "# ==========================================================\n",
        "# 👉 Students will choose ONE target depending on their task\n",
        "\n",
        "df[\"target_churn\"] = (\n",
        "    (df[\"last_login_days\"] > 15).astype(int) * 0.4 +\n",
        "    (df[\"num_transactions\"] < 5).astype(int) * 0.3 +\n",
        "    (df[\"total_spend\"] < 500).astype(int) * 0.3 +\n",
        "    np.random.rand(n) * 0.3\n",
        ") > 0.7\n",
        "\n",
        "df[\"target_churn\"] = df[\"target_churn\"].astype(int)\n",
        "\n",
        "# Revenue Prediction (Regression)\n",
        "df[\"target_revenue\"] = (\n",
        "    df[\"monthly_spend\"] *\n",
        "    (0.7 + 0.6 * np.random.rand(n)) +\n",
        "    df[\"num_transactions\"] * 2 +\n",
        "    np.random.normal(0, 50, n)\n",
        ")\n",
        "\n",
        "# Fraud Detection (Classification)\n",
        "df[\"target_fraud\"] = (\n",
        "    (df[\"num_transactions\"] > 70).astype(int) * 0.5 +\n",
        "    (df[\"avg_transaction_value\"] > 200).astype(int) * 0.3 +\n",
        "    (df[\"last_login_days\"] < 2).astype(int) * 0.2 +\n",
        "    np.random.rand(n) * 0.3\n",
        ") > 0.75\n",
        "\n",
        "df[\"target_fraud\"] = df[\"target_fraud\"].astype(int)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 7,
      "id": "7b344413",
      "metadata": {
        "id": "7b344413"
      },
      "outputs": [],
      "source": [
        "# Add 10% noise to all classification targets\n",
        "for col in [\"target_churn\", \"target_fraud\"]:\n",
        "    noise_mask = np.random.rand(n) < 0.1\n",
        "    df.loc[noise_mask, col] = 1 - df.loc[noise_mask, col]"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 8,
      "id": "d41a7e57",
      "metadata": {
        "id": "d41a7e57"
      },
      "outputs": [],
      "source": [
        "# ==========================================================\n",
        "# ✂️ STEP 4 — TRAIN / TEST SPLIT\n",
        "# ==========================================================\n",
        "# 80% training, 20% testing\n",
        "\n",
        "train = df.sample(frac=0.8, random_state=42)\n",
        "test = df.drop(train.index)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "id": "L4EhdbP6G0jb",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "L4EhdbP6G0jb",
        "outputId": "19473a31-96b6-437c-d824-d9b17ec122f5"
      },
      "outputs": [],
      "source": [
        "# ============================================================\n",
        "# 💾 STEP 5 — SAVE DATA (Google Drive version)\n",
        "# ============================================================\n",
        "\n",
        "import os\n",
        "\n",
        "# Create the folder if it doesn't exist\n",
        "BASE = ''\n",
        "os.makedirs(BASE + 'data', exist_ok=True)\n",
        "\n",
        "# Save files\n",
        "train.to_csv(BASE + 'data/train.csv', index=False)\n",
        "test.to_csv(BASE + 'data/test.csv', index=False)"
      ]
    },
